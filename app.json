{
  "expo": {
    "name": "NoteMusic",
    "slug": "notemusic",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "android": {
      "package": "com.notemusic.app",
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0087D3"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.notemusic.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ee739f31-d8e8-4f6a-8655-58742bb7756b"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
